{
  "expo": {
    "name": "UI Playground",
    "slug": "expo-ui-playground",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "expouiplayground",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.expo-ui-playground",
      "appleTeamId": "T2A8YY9YDW",
      "icon": "./assets/icon.icon",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-video",
      "expo-image"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "df386b77-43d1-42b7-aa1a-64228d6b455b"
      }
    }
  }
}
