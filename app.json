{
  "expo": {
    "name": "UI Playground",
    "slug": "expo-ui-playground",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "expouiplayground",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.expo-ui-playground",
      "icon": "./assets/icon.icon/Assets/icon-1756312748268.png",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-video",
      "expo-image"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a0af2908-d78b-4c1f-85c8-c6d7cace7309"
      }
    }
  }
}
